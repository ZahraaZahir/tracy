generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  profile      Profile?
  saveState    SaveState?
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  username  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SaveState {
  userId        String       @id
  posX          Float        @default(0)
  posY          Float        @default(0)
  mapName       String       @default("main_world")
  fixedGlitches GameEntity[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameEntity {
  id            String      @id
  templateCode  String
  solutionMap   Json
  errorMessages Json
  createdAt     DateTime    @default(now())
  fixedBy       SaveState[]
}
